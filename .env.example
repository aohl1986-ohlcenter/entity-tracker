# Postgres connection (Vercel Postgres / Neon)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Serper.dev — https://serper.dev (2500 free credits on signup)
SERPER_API_KEY=

# Google Gemini (AI Studio) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Vercel Cron auth — set to a random string, used in Authorization header
CRON_SECRET=

# Default entity to render on the dashboard root
DEFAULT_ENTITY_SLUG=jens-langkammer

# Resend (https://resend.com) — free tier 3000/mo
RESEND_API_KEY=
ALERT_EMAIL_FROM=Pragma-Code Tracker <onboarding@resend.dev>
ALERT_EMAIL_TO=
NEXT_PUBLIC_BASE_URL=https://tracker.pragma-code.de
