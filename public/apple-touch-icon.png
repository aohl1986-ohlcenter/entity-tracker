<!DOCTYPE html><html lang="de"> <head><meta charset="UTF-8"><!-- Prevent dark mode flash: apply saved theme before first paint.
		     Light-Mode-CSS (home-light.css) wird nur geladen, wenn das Theme
		     tatsaechlich „light" ist — spart ~7 KiB im kritischen Pfad fuer
		     die ~95 % Dark-Mode-Nutzer. Helper auf window, damit der
		     Theme-Toggle ihn beim Umschalten aufrufen kann. --><script>
			(function() {
				var t = localStorage.getItem('theme');
				var theme = t || 'dark';
				document.documentElement.setAttribute('data-theme', theme);
				window.__ensureLightCss = function() {
					if (document.getElementById('home-light-css')) return;
					var l = document.createElement('link');
					l.id = 'home-light-css';
					l.rel = 'stylesheet';
					l.href = '/styles/home-light.css';
					document.head.appendChild(l);
				};
				if (theme === 'light') window.__ensureLightCss();
			})();
